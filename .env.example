# FloatChart Configuration
# Copy this file to .env at project root: cp .env.example .env

# ============================================
# 🏠 DATABASE (REQUIRED)
# ============================================
# Option 1: DuckDB (zero-config, great for getting started)
DATABASE_URL=duckdb:///prototype.duckdb

# Option 2: PostgreSQL (for large datasets)
# Install PostgreSQL: https://www.postgresql.org/download/
# Create database: CREATE DATABASE floatchart;
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/floatchart

# ============================================
# 🧠 AI PROVIDER - NVIDIA NIM (REQUIRED)
# ============================================
# Get your free API key at: https://build.nvidia.com
#   ✅ Strongest reasoning (Llama 3.3 70B)
#   ✅ Enterprise-grade speed
#   ✅ Free trial credits available
#
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ============================================
# 💎 Optional: Additional AI providers
# ============================================
# Set USE_PREMIUM_AI=true to prefer paid providers
# USE_PREMIUM_AI=false

# OpenAI GPT-4o (Best quality)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (Excellent reasoning)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek (Very cheap, excellent reasoning)
# DEEPSEEK_API_KEY=your_deepseek_key
